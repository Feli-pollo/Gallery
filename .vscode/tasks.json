{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "sqlproj: Build DatabaseProjectPokemonDB",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"/workspaces/Gallery/src/DB/DatabaseProjectPokemonDB/DatabaseProjectPokemonDB.sqlproj"
			],
			"problemMatcher": "$sqlproj-problem-matcher",
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Builds the DatabaseProjectPokemonDB SQL project"
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/Backend/Backend.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/src/Backend/Backend.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/src/Backend/Backend.csproj"
            ],
            "problemMatcher": "$msCompile"
        }
	]
}